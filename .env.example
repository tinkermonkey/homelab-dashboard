# Server Configuration
PORT=3001
HOST=localhost

# Logging
LOG_LEVEL=info

# SigNoz Monitoring & Alerting
SIGNOZ_URL=http://localhost:4317
SIGNOZ_API_TOKEN=

# ntopng Network Monitoring — token auth (Settings → Preferences → Token-based Auth)
NTOPNG_URL=http://localhost:3000
NTOPNG_TOKEN=

# ElastiFlow (Elasticsearch) — Basic auth
ELASTIFLOW_URL=http://localhost:9200
ELASTIFLOW_USER=elastic
ELASTIFLOW_PASSWORD=

# phone-home — base URL for REST API (/v1/servers/{server}/tools/{tool}) and chat
# Both use the same bearer token (PHONE_HOME_CHAT_TOKEN)
PHONE_HOME_URL=http://localhost:8000
PHONE_HOME_CHAT_URL=http://localhost:8000/chat
PHONE_HOME_CHAT_TOKEN=

# API Configuration (Client only)
# Base URL for API requests (only set for non-proxied deployments)
# For local dev, omit this so the client uses the Vite proxy at /api
# VITE_API_BASE=http://localhost:3001/api
