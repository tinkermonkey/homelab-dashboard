# Server Configuration
PORT=3001
HOST=localhost

# API Configuration
# Base URL for API requests (only set for non-proxied deployments)
# For local dev, omit this so the client uses the Vite proxy at /api
# VITE_API_BASE=http://localhost:3001/api

# MCP Server Configuration
# Endpoint for MCP servers (proxy to phone-home service)
MCP_ENDPOINT=http://agent:3210/mcp/

# Optional: External Service URLs
# These would be used by the server to proxy data from external services
SIGNOZ_URL=http://localhost:4317
NTOPNG_URL=http://localhost:3000
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
GRAFANA_URL=http://localhost:3000

# Optional: Credentials (never exposed to client)
# API_KEY=your-api-key-here
# GRAFANA_API_KEY=your-grafana-key-here
