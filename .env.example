# Server Configuration
PORT=3001
HOST=localhost

# Logging
LOG_LEVEL=info

# SigNoz Monitoring & Alerting
SIGNOZ_URL=http://localhost:4317
SIGNOZ_API_TOKEN=

# ntopng Network Monitoring
NTOPNG_URL=http://localhost:3000
NTOPNG_USER=admin
NTOPNG_PASSWORD=admin

# ElastiFlow Network Analytics
ELASTIFLOW_URL=http://localhost:9090

# phone-home MCP Server (sibling repo)
PHONE_HOME_URL=http://localhost:8000
PHONE_HOME_MCP_URL=http://agent:3210/mcp/
PHONE_HOME_CHAT_URL=http://localhost:8000/chat

# API Configuration (Client only)
# Base URL for API requests (only set for non-proxied deployments)
# For local dev, omit this so the client uses the Vite proxy at /api
# VITE_API_BASE=http://localhost:3001/api
